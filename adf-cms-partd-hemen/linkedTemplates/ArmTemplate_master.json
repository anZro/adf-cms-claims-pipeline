{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-cms-partd-hemen"
		},
		"ls_blob_cms_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'ls_blob_cms'"
		},
		"ls_neon_postgres_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_neon_postgres'"
		},
		"ls_neon_postgres_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "ep-delicate-silence-aq24pnih.c-8.us-east-1.aws.neon.tech"
		},
		"ls_neon_postgres_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "neondb"
		},
		"ls_neon_postgres_properties_typeProperties_username": {
			"type": "string",
			"defaultValue": "neondb_owner"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-cms-partd-hemen_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ls_blob_cms_connectionString": {
						"value": "[parameters('ls_blob_cms_connectionString')]"
					},
					"ls_neon_postgres_password": {
						"value": "[parameters('ls_neon_postgres_password')]"
					},
					"ls_neon_postgres_properties_typeProperties_server": {
						"value": "[parameters('ls_neon_postgres_properties_typeProperties_server')]"
					},
					"ls_neon_postgres_properties_typeProperties_database": {
						"value": "[parameters('ls_neon_postgres_properties_typeProperties_database')]"
					},
					"ls_neon_postgres_properties_typeProperties_username": {
						"value": "[parameters('ls_neon_postgres_properties_typeProperties_username')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}